st.info(f"Will evaluate {exp_id} — chunk size {chunk_size} chars, k={top_k}")

if st.button(f"Run local metrics for {exp_id}", type="primary", use_container_width=True):

    if indexed_paths:
        with st.spinner(f"Preparing index for chunk size {chunk_size}..."):
            rag.build_index(indexed_paths, chunk_size=chunk_size)

    model = rag.get_embedding_model()

    sims, precisions, recalls, rr_scores = [], [], [], []
    prog = st.progress(0, text="Generating answers and scoring...")

    quota_hit = False
    try:
        for i, q in enumerate(TEST_QUESTIONS):
            gt = ground_truth.get(q["id"], {})
            ref_answer = gt.get("reference_answer", "").strip()
            gt_pages_raw = gt.get("ground_truth_pages", "").strip()

            if not ref_answer:
                continue  # skip questions with no ground truth yet

            prog.progress((i + 1) / 20, text=f"Question {q['id']}/20: {q['q'][:50]}...")

            chunks = rag.search(q["q"], top_k=top_k)
            answer = ask_llama(q["q"], chunks, [])
            time.sleep(4)  # stay under Gemini free tier's 15 RPM cap

            # --- Semantic similarity (all questions with a reference answer) ---
            emb_pair = model.encode([answer, ref_answer])
            a_vec, r_vec = emb_pair[0], emb_pair[1]
            cos_sim = float(np.dot(a_vec, r_vec) / (np.linalg.norm(a_vec) * np.linalg.norm(r_vec)))
            sims.append(max(0.0, cos_sim))

            # --- Retrieval precision / recall / MRR (in-scope questions only) ---
            if gt_pages_raw:
                gt_pages = {p.strip() for p in gt_pages_raw.split(",") if p.strip()}
                retrieved_pages_list = [str(c["page_number"]) for c in chunks]
                retrieved_pages_set  = set(retrieved_pages_list)

                relevant_retrieved = retrieved_pages_set & gt_pages
                precision = len(relevant_retrieved) / len(retrieved_pages_set) if retrieved_pages_set else 0.0
                recall    = len(relevant_retrieved) / len(gt_pages) if gt_pages else 0.0
                precisions.append(precision)
                recalls.append(recall)

                rr = 0.0
                for rank, p in enumerate(retrieved_pages_list, start=1):
                    if p in gt_pages:
                        rr = 1.0 / rank
                        break
                rr_scores.append(rr)
    except Exception as e:
        err_str = str(e)
        if "rate_limit" in err_str.lower() or "429" in err_str or "quota" in err_str.lower():
            quota_hit = True
            st.warning(
                f"Hit Gemini's daily quota after generating {len(sims)} answer(s) — "
                "this still happens here because generating the answers themselves "
                "needs the main chat model, the same one your regular testing uses. "
                "What this page DOES avoid is the 200+ extra judge calls RAGAS "
                "makes on top of that, which is what drains quota fastest."
            )
            with st.expander("Technical details"):
                st.code(err_str)
        else:
            st.error(f"Answer generation failed: {err_str}")
            st.stop()

    prog.empty()

    if quota_hit and not sims:
        st.stop()

    if not sims:
        st.error("No ground truth filled in yet — fill in at least one reference answer above.")
        st.stop()

    avg_sim  = round(float(np.mean(sims)) * 100, 1)
    avg_prec = round(float(np.mean(precisions)) * 100, 1) if precisions else None
    avg_rec  = round(float(np.mean(recalls)) * 100, 1) if recalls else None
    avg_mrr  = round(float(np.mean(rr_scores)) * 100, 1) if rr_scores else None

    parts = [v for v in (avg_sim, avg_prec, avg_rec, avg_mrr) if v is not None]
    overall = round(sum(parts) / len(parts), 1)

    save_local_result(
        exp_id, chunk_size, top_k, avg_sim, avg_prec, avg_rec, avg_mrr,
        overall, len(sims)
    )

    st.session_state.local_latest = {
        "experiment":          exp_id,
        "chunk_size":          chunk_size,
        "top_k":               top_k,
        "semantic_similarity": avg_sim,
        "retrieval_precision": avg_prec,
        "retrieval_recall":    avg_rec,
        "mrr":                 avg_mrr,
        "overall":             overall,
        "num_questions":       len(sims),
    }
    st.rerun()


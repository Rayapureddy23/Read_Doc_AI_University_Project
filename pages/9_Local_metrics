def init_tables():
    os.makedirs(os.path.dirname(DB), exist_ok=True)
    conn = sqlite3.connect(DB)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS local_ground_truth (
            question_id        INTEGER PRIMARY KEY,
            reference_answer   TEXT,
            ground_truth_pages TEXT
        )
    """)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS local_metrics_results (
            id                       INTEGER PRIMARY KEY AUTOINCREMENT,
            experiment               TEXT NOT NULL,
            chunk_size               INTEGER,
            top_k                    INTEGER,
            semantic_similarity      REAL,
            retrieval_precision      REAL,
            retrieval_recall         REAL,
            mrr                      REAL,
            overall                  REAL,
            num_questions            INTEGER,
            created_at               TEXT
        )
    """)
    conn.commit()
    conn.close()

def load_ground_truth():
    conn = sqlite3.connect(DB)
    try:
        df = pd.read_sql_query("SELECT * FROM local_ground_truth", conn)
    except Exception:
        df = pd.DataFrame()
    conn.close()
    gt = {}
    for _, row in df.iterrows():
        gt[int(row["question_id"])] = {
            "reference_answer":   row["reference_answer"] or "",
            "ground_truth_pages": row["ground_truth_pages"] or "",
        }
    return gt

def save_ground_truth(question_id, reference_answer, ground_truth_pages):
    conn = sqlite3.connect(DB)
    conn.execute("""
        INSERT INTO local_ground_truth (question_id, reference_answer, ground_truth_pages)
        VALUES (?, ?, ?)
        ON CONFLICT(question_id) DO UPDATE SET
            reference_answer = excluded.reference_answer,
            ground_truth_pages = excluded.ground_truth_pages
    """, (question_id, reference_answer, ground_truth_pages))
    conn.commit()
    conn.close()

def save_local_result(experiment, chunk_size, top_k, sim, prec, rec, mrr, overall, num_q):
    conn = sqlite3.connect(DB)
    conn.execute("DELETE FROM local_metrics_results WHERE experiment = ?", (experiment,))
    conn.execute("""
        INSERT INTO local_metrics_results
            (experiment, chunk_size, top_k, semantic_similarity, retrieval_precision,
             retrieval_recall, mrr, overall, num_questions, created_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, datetime('now'))
    """, (experiment, chunk_size, top_k, sim, prec, rec, mrr, overall, num_q))
    conn.commit()
    conn.close()

def load_local_results():
    if not os.path.exists(DB):
        return pd.DataFrame()
    conn = sqlite3.connect(DB)
    try:
        df = pd.read_sql_query("SELECT * FROM local_metrics_results ORDER BY experiment", conn)
    except Exception:
        df = pd.DataFrame()
    conn.close()
    return df

